# --- Database (Supabase Postgres) ---
# Dashboard → Project Settings → Database
# Use "Transaction pooler" URI for DATABASE_URL (port 6543, add ?pgbouncer=true if not present).
# Use direct/session URI on port 5432 for DIRECT_URL (required for `prisma migrate` / `db push`).
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Auth (Auth.js / NextAuth v5) ---
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Production: your Vercel URL. Local dev: http://localhost:3000
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Optional OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
